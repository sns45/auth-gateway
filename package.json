{
  "name": "hono-auth-gateway",
  "version": "1.1.1",
  "description": "Hono.js Authentication Gateway for Convex Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev:sync": "doppler secrets download --no-file --format env --project auth --config dev > .dev.vars",
    "dev": "bash scripts/dev.sh",
    "dev:local": "wrangler dev src/index.ts --config config/wrangler.toml --local",
    "dev:remote": "doppler run -- wrangler dev src/index.ts --config config/wrangler.toml",
    "deploy": "doppler run -- wrangler deploy",
    "deploy:staging": "doppler run --project auth --config stg -- wrangler deploy",
    "deploy:production": "doppler run --project auth --config prd -- wrangler deploy",
    "deploy:doppler": "doppler run -- wrangler deploy src/index.ts --config config/wrangler.toml",
    "provision": "bash scripts/provision-worker.sh",
    "provision:worker": "bash scripts/provision-worker.sh",
    "build": "tsc -p tsconfig.build.json && esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=node",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "typecheck:all": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "doppler:setup": "doppler setup",
    "doppler:sync": "bash scripts/sync-doppler-to-wrangler.sh",
    "provision:kv": "bash scripts/manual-provision.sh",
    "logs": "wrangler tail --config config/wrangler.toml",
    "logs:error": "wrangler tail --config config/wrangler.toml --format=json | grep ERROR",
    "test:websocket": "wscat -c ws://localhost:8787/api/ws",
    "test:websocket:prod": "wscat -c wss://auth.example.com/api/ws"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.2",
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.3",
    "hono-rate-limiter": "^0.4.0",
    "jose": "^5.9.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "@playwright/test": "^1.48.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "convex": "^1.26.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "wrangler": "^4.32.0",
    "wscat": "^5.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
